# Prefix key
unbind C-b
set -g prefix `

bind-key ` last-window
bind u send-keys C-l \; run-shell "sleep .3s" \; clear-history

# Clipboard copy with xclip
bind -T copy-mode-vi y send -X copy-pipe-and-cancel "xclip -selection clipboard -in"
set -s set-clipboard on
set -as terminal-features ',rxvt-unicode-256color:clipboard'

set -g mouse on

set-option -g history-limit 5000
set -g status-position bottom

# Vim keybindings
setw -g mode-keys vi
bind-key h select-pane -L
bind-key j select-pane -D
bind-key k select-pane -U
bind-key l select-pane -R

# Resize with Ctrl + Arrows for resize
bind -n C-S-Down resize-pane -D 5
bind -n C-S-Up resize-pane -U 5
bind -n C-S-Left resize-pane -L 5
bind -n C-S-Right resize-pane -R 5

# Start numbering at 1
set -g base-index 1
set -g pane-base-index 1
set-window-option -g pane-base-index 1
set -g renumber-windows on

# Name windows after their current folder (a manual rename still wins, per window)
set -g automatic-rename on
set -g automatic-rename-format '#{b:pane_current_path}'

# PLUGINS
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'dracula/tmux'

# THEME SETTINGS
set -g @dracula-show-powerline 1
set -g @dracula-plugins "cwd git cpu-usage ram-usage ssh-session"
set -g @dracula-who-flags true
set -g @dracula-show-left-icon session
set -g @dracula-show-fahrenheit false
set -g @dracula-time-format "%H:%M %d/%m/%Y"
set -g @dracula-show-time true

set -g @dracula-colors "
white='#EBDBB2'
gray='#282828'
dark_gray='#282828'
light_purple='#B16286'
dark_purple='#CC241D'
cyan='#689D6A'
green='#98971A'
orange='#D65D0E'
red='#CC241D'
pink='#D3869B'
yellow='#D79921'
"

# split windows in same directory
bind '"' split-window -v -c "#{pane_current_path}"
bind % split-window -h -c "#{pane_current_path}"
bind c new-window -c "#{pane_current_path}"

# Kill panes easily
unbind-key z
bind-key z kill-pane
unbind-key x
bind-key x kill-window

run '~/.tmux/plugins/tpm/tpm'

# Pane borders: highlight the whole border of the active pane (after tpm so dracula can't override)
set -g pane-border-lines heavy
# 'colour'/'both' paint only half the border in two-pane windows; 'arrows' keeps the full outline
set -g pane-border-indicators arrows
# No pane-border-status: it replaces shared borders with a per-pane line,
# so a border only turns red when the pane below/right of it is focused.
set -g pane-border-status off
set -g pane-border-style 'fg=#3c3836'
set -g pane-active-border-style 'fg=#CC241D,bold'

# Make cwd/branch instant: path-aware scripts + a redraw on every switch
run-shell '~/.tmuxrc/scripts/fast_status.sh'
set -g status-interval 1
set-hook -g after-select-pane 'refresh-client -S'
set-hook -g after-select-window 'refresh-client -S'
set-hook -g after-split-window 'refresh-client -S'
set-hook -g session-window-changed 'refresh-client -S'
